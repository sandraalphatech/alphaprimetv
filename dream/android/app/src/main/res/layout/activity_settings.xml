<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Barra do topo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/settings_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Conteúdo com scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="20dp">

            <!-- Tipo de ligação -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de ligação"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rg_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rb_m3u"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URL M3U"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="24dp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rb_xtream"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xtream Codes"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent" />
            </RadioGroup>

            <!-- Formulário M3U -->
            <LinearLayout
                android:id="@+id/form_m3u"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URL da lista M3U"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_m3u"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/m3u_url_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#40E5E7EB"
                    android:textSize="13sp"
                    android:background="@color/surface"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:imeOptions="actionDone"
                    android:inputType="textUri" />
            </LinearLayout>

            <!-- Formulário Xtream -->
            <LinearLayout
                android:id="@+id/form_xtream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Servidor"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_server"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/xtream_server_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#40E5E7EB"
                    android:textSize="13sp"
                    android:background="@color/surface"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:inputType="textUri"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilizador"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_user"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/xtream_user_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#40E5E7EB"
                    android:textSize="13sp"
                    android:background="@color/surface"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:inputType="text"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senha"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_pass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/xtream_pass_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#40E5E7EB"
                    android:textSize="13sp"
                    android:background="@color/surface"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:inputType="textPassword" />
            </LinearLayout>

            <!-- Botão Guardar -->
            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="@string/save"
                android:backgroundTint="@color/accent"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Mensagem de sucesso -->
            <TextView
                android:id="@+id/tv_save_ok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/saved_ok"
                android:textColor="@color/success"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
